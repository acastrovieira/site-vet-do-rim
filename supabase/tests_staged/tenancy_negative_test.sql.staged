SET CONSTRAINTS ALL IMMEDIATE;

-- Vet A: positive access within Clinic A and negative access to Clinic B.
SET LOCAL ROLE authenticated;
SELECT set_config('request.jwt.claim.sub', current_setting('test.vet_a'), true);
SELECT set_config(
  'request.jwt.claims',
  jsonb_build_object('sub', current_setting('test.vet_a'), 'role', 'authenticated')::text,
  true
);
SELECT pg_temp.assert_true(
  auth.uid() = current_setting('test.vet_a')::uuid,
  'Vet A JWT emulation must be active'
);

SELECT pg_temp.assert_eq((SELECT count(*) FROM public.profiles), 1, 'Vet A sees only own profile');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics), 1, 'Vet A sees only Clinic A');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics WHERE id = 'b0000000-0000-4000-8000-000000000002'), 0, 'Vet A cannot see Clinic B');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinic_memberships), 1, 'Vet A sees only own membership');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.tutores), 1, 'Vet A sees only Clinic A tutores');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.pets), 1, 'Vet A sees only Clinic A pets');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.triagens), 1, 'Vet A sees only Clinic A triagens');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.follow_ups), 1, 'Vet A sees only Clinic A follow-ups');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.colaboradores), 1, 'Vet A sees only Clinic A collaborators');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.laudos_pdf), 1, 'Vet A sees only Clinic A laudos');

WITH inserted AS (
  INSERT INTO public.tutores (clinic_id, nome, email, telefone)
  VALUES (
    'a0000000-0000-4000-8000-000000000001',
    'Tutor A permitido',
    'tutor-a-ok@adr001.example.test',
    '11000000003'
  )
  RETURNING 1
)
SELECT pg_temp.assert_eq((SELECT count(*) FROM inserted), 1, 'Vet A may insert a Clinic A tutor');

SELECT pg_temp.expect_error(
  $sql$INSERT INTO public.tutores (clinic_id, nome, email, telefone)
       VALUES ('b0000000-0000-4000-8000-000000000002', 'Ataque B',
               'attack-b@adr001.example.test', '11000000004')$sql$,
  'Vet A cannot insert a Clinic B tutor'
);
SELECT pg_temp.expect_error(
  $sql$INSERT INTO public.pets (clinic_id, tutor_id, nome, especie)
       VALUES ('a0000000-0000-4000-8000-000000000001',
               'b1000000-0000-4000-8000-000000000002',
               'Relação cruzada', 'canino')$sql$,
  'a Clinic A pet cannot reference a Clinic B tutor'
);
SELECT pg_temp.expect_error(
  $sql$INSERT INTO public.laudos_pdf
         (clinic_id, pet_id, nome_arquivo, tamanho_bytes)
       VALUES ('b0000000-0000-4000-8000-000000000002',
               'b2000000-0000-4000-8000-000000000002', 'attack.pdf', 10)$sql$,
  'Vet A cannot reserve a Clinic B laudo'
);
SELECT pg_temp.expect_error(
  $sql$UPDATE public.tutores
          SET clinic_id = 'b0000000-0000-4000-8000-000000000002'
        WHERE id = 'a1000000-0000-4000-8000-000000000001'$sql$,
  'Vet A cannot mutate tenant identity'
);
SELECT pg_temp.expect_error(
  $sql$DELETE FROM public.tutores
        WHERE id = 'a1000000-0000-4000-8000-000000000001'$sql$,
  'Vet A has no direct delete privilege'
);
SELECT pg_temp.expect_error(
  format(
    'INSERT INTO public.clinic_memberships (clinic_id, user_id, role, status, created_by) VALUES (%L, %L, %L, %L, %L)',
    'a0000000-0000-4000-8000-000000000001',
    current_setting('test.admin_b'),
    'vet',
    'active',
    current_setting('test.vet_a')
  ),
  'Vet A cannot create memberships directly'
);

UPDATE public.tutores
   SET nome = 'Tentativa invisível'
 WHERE id = 'b1000000-0000-4000-8000-000000000002';
SELECT pg_temp.assert_eq(
  (SELECT count(*) FROM public.tutores WHERE nome = 'Tentativa invisível'),
  0,
  'Vet A cannot update an invisible Clinic B row'
);

RESET ROLE;
SELECT pg_temp.assert_eq(
  (SELECT count(*) FROM public.tutores WHERE id = 'b1000000-0000-4000-8000-000000000002' AND nome = 'Tutor B'),
  1,
  'Clinic B data remains unchanged after Vet A attempts'
);

-- Revocation is driven by the database membership, not mutable JWT metadata.
UPDATE public.clinic_memberships
   SET status = 'inactive'
 WHERE clinic_id = 'a0000000-0000-4000-8000-000000000001'
   AND user_id = current_setting('test.vet_a')::uuid;

SET LOCAL ROLE authenticated;
SELECT set_config('request.jwt.claim.sub', current_setting('test.vet_a'), true);
SELECT set_config(
  'request.jwt.claims',
  jsonb_build_object('sub', current_setting('test.vet_a'), 'role', 'authenticated')::text,
  true
);
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics), 0, 'inactive Vet A sees no clinic');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.tutores), 0, 'inactive Vet A sees no tutores');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.pets), 0, 'inactive Vet A sees no pets');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.triagens), 0, 'inactive Vet A sees no triagens');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.follow_ups), 0, 'inactive Vet A sees no follow-ups');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.colaboradores), 0, 'inactive Vet A sees no collaborators');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.laudos_pdf), 0, 'inactive Vet A sees no laudos');
RESET ROLE;

UPDATE public.clinic_memberships
   SET status = 'active'
 WHERE clinic_id = 'a0000000-0000-4000-8000-000000000001'
   AND user_id = current_setting('test.vet_a')::uuid;

-- Admin A sees the Clinic A roster but remains isolated from Clinic B.
SET LOCAL ROLE authenticated;
SELECT set_config('request.jwt.claim.sub', current_setting('test.admin_a'), true);
SELECT set_config(
  'request.jwt.claims',
  jsonb_build_object('sub', current_setting('test.admin_a'), 'role', 'authenticated')::text,
  true
);
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics), 1, 'Admin A sees only Clinic A');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinic_memberships), 2, 'Admin A sees Clinic A roster');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinic_memberships WHERE clinic_id = 'b0000000-0000-4000-8000-000000000002'), 0, 'Admin A cannot see Clinic B roster');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.tutores WHERE clinic_id = 'b0000000-0000-4000-8000-000000000002'), 0, 'Admin A cannot see Clinic B tutores');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.laudos_pdf WHERE clinic_id = 'b0000000-0000-4000-8000-000000000002'), 0, 'Admin A cannot see Clinic B laudos');
RESET ROLE;

-- Vet B independently proves the inverse tenant boundary.
SET LOCAL ROLE authenticated;
SELECT set_config('request.jwt.claim.sub', current_setting('test.vet_b'), true);
SELECT set_config(
  'request.jwt.claims',
  jsonb_build_object('sub', current_setting('test.vet_b'), 'role', 'authenticated')::text,
  true
);
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics), 1, 'Vet B sees only Clinic B');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.clinics WHERE id = 'a0000000-0000-4000-8000-000000000001'), 0, 'Vet B cannot see Clinic A');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.tutores), 1, 'Vet B sees only Clinic B tutores');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.pets), 1, 'Vet B sees only Clinic B pets');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.triagens), 1, 'Vet B sees only Clinic B triagens');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.follow_ups), 1, 'Vet B sees only Clinic B follow-ups');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.colaboradores), 1, 'Vet B sees only Clinic B collaborators');
SELECT pg_temp.assert_eq((SELECT count(*) FROM public.laudos_pdf), 1, 'Vet B sees only Clinic B laudos');
RESET ROLE;

-- Referential anonymization must not be defeated by the immutability trigger.
DELETE FROM public.clinic_memberships
 WHERE clinic_id = 'a0000000-0000-4000-8000-000000000001'
   AND user_id = current_setting('test.vet_a')::uuid;
SET CONSTRAINTS ALL IMMEDIATE;
SELECT pg_temp.assert_eq(
  (
    SELECT count(*)
      FROM public.laudos_pdf
     WHERE id = 'a6000000-0000-4000-8000-000000000001'
       AND vet_id IS NULL
  ),
  1,
  'membership deletion must apply the reviewed laudo vet_id SET NULL action'
);
SELECT pg_temp.assert_eq(
  (
    SELECT count(*)
      FROM public.colaboradores
     WHERE id = 'a5000000-0000-4000-8000-000000000001'
       AND supabase_uid IS NULL
  ),
  1,
  'membership deletion must apply the collaborator supabase_uid SET NULL action'
);

SELECT 'ADR-001 Vet A x Vet B negative tests passed; fixtures will be rolled back' AS result;

ROLLBACK;
