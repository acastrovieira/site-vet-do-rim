# Vet do Rim Web - Next.js
# Copie para .env.local e preencha com valores reais do projeto.
# Nao use hosts dummy em ambientes de teste de login/cadastro.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
# Use a current publishable key (sb_publishable_*) or legacy anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-publishable-or-anon-key

# E2E remoto local. Restrito a homologacao isolada e dados sinteticos.
# O project ref e a URL precisam apontar para o mesmo projeto. Scripts que
# alteram dados recusam producao e exigem confirmacao vinculada ao alvo.
SUPABASE_PROJECT_REF=replace-with-staging-project-ref
SUPABASE_ENVIRONMENT=staging
SUPABASE_MUTATION_CONFIRMATION=CONFIRM_STAGING_MUTATION:replace-with-staging-project-ref
# Use a current secret key (sb_secret_*) or legacy service_role key. Nunca
# exponha essa chave no browser ou no historico de comandos.
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-secret-or-service-role-key
E2E_CLEANUP_RUN_ID=

# Readiness/automacao server-side. Nunca prefixe com NEXT_PUBLIC_.
# A senha do banco e necessaria apenas para validacoes CLI controladas.
SUPABASE_DB_PASSWORD=replace-with-staging-database-password
# Auditoria de catalogo somente leitura. O modo padrao de audit:staging nao
# usa estas variaveis nem abre rede. A execucao remota valida todas antes de
# iniciar psql e recusa qualquer ambiente diferente de staging.
STAGING_AUDIT_CONFIRMATION=CONFIRM_STAGING_READ_ONLY:replace-with-staging-project-ref
SUPABASE_DB_HOST=db.replace-with-staging-project-ref.supabase.co
SUPABASE_DB_USER=postgres
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PORT=5432
# Aplicado somente quando check:remote-readiness recebe --remote.
# Faixa aceita: 1000-15000 ms.
REMOTE_READINESS_TIMEOUT_MS=5000
VPS_HEALTH_URL=https://staging-health.example.invalid
# Minimo de 32 caracteres; VPS_HEALTH_URL deve usar HTTPS e nao pode redirecionar.
CRON_SECRET=replace-with-at-least-32-random-characters
# Timeout por dependencia do cron. Faixa aceita: 1000-10000 ms.
KEEP_ALIVE_TIMEOUT_MS=5000

# Analytics opcional
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Edge Functions / Supabase backend secrets ficam no Dashboard do Supabase,
# nao em variaveis NEXT_PUBLIC_*:
# SUPABASE_URL
# GEMINI_API_KEY
# GEMINI_MODEL=gemini-3.5-flash
# OPENAI_API_KEY
# OPENAI_MODEL=gpt-5.6-terra
